{
  "info": {
    "name": "Job Scheduler API",
    "description": "API for managing and scheduling jobs with Quartz",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jobId\", jsonData.id);",
                  "    pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
                  "    pm.test(\"Response has job ID\", function () { pm.expect(jsonData.id).to.exist; });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Job - 5 Minutes\",\n  \"apiEndpoint\": \"https://jsonplaceholder.typicode.com/posts/1\",\n  \"method\": \"GET\",\n  \"headers\": {\n    \"Accept\": \"application/json\"\n  },\n  \"scheduleTime\": \"2026-03-12T18:14:27Z\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/jobs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "jobs"]
            }
          },
          "response": []
        },
