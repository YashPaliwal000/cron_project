{
  "info": {
    "name": "Job Scheduler API",
    "description": "API for managing and scheduling jobs with Quartz and JWT authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"authToken\", jsonData.token);",
                  "    pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "    pm.test(\"Response has token\", function () { pm.expect(jsonData.token).to.exist; });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jobId\", jsonData.id);",
                  "    pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
                  "    pm.test(\"Response has job ID\", function () { pm.expect(jsonData.id).to.exist; });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Job - 5 Minutes\",\n  \"endpoint\": \"https://jsonplaceholder.typicode.com/posts/1\",\n  \"method\": \"GET\",\n  \"headers\": \"{\\\"Accept\\\": \\\"application/json\\\"}\",\n  \"payload\": \"{\\\"key\\\": \\\"value\\\"}\",\n  \"scheduleType\": \"ONE_TIME\",\n  \"scheduleTime\": \"2026-03-15T18:14:27\",\n  \"timeZone\": \"Asia/Kolkata\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/jobs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "jobs"]
            }
          },
          "response": []
        },
